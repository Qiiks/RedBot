generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubjectType {
  USER
  ROLE
}

enum TimedActionType {
  TIMEOUT
  BAN
}

enum TimedActionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AuditCategory {
  MODERATION
  MEMBER
  SERVER
  MESSAGE
}

model HealthProbe {
  id        String   @id @default(cuid())
  message   String   @default("ok")
  createdAt DateTime @default(now())

  @@map("health_probes")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Guild {
  id                  String               @id
  name                String
  ownerId             String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  allowlistedGuild    AllowlistedGuild?
  permissionOverrides PermissionOverride[]
  warnings            Warning[]
  timedActions        TimedAction[]
  roleSnapshots       RolePersistenceSnapshot[]
  reactionRoleMessages ReactionRoleMessage[]
  settings            GuildSettings?
  auditEvents         AuditEvent[]
}

model GuildSettings {
  guildId                 String   @id
  logChannelId            String?
  contentSnapshotsEnabled Boolean  @default(false)
  logRetentionDays        Int      @default(180)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  guild                   Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model AuditEvent {
  id        String        @id @default(cuid())
  guildId   String
  category  AuditCategory
  action    String
  actorId   String?
  targetId  String?
  metadata  Json          @db.JsonB
  createdAt DateTime      @default(now())
  guild     Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([guildId, category, createdAt])
  @@index([guildId, action, createdAt])
}

model AllowlistedGuild {
  guildId   String   @id
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model PermissionOverride {
  guildId     String
  subjectId   String
  subjectType SubjectType
  command     String
  allow       Boolean
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  guild       Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([guildId, subjectId, subjectType, command])
  @@index([guildId, command])
  @@index([guildId, subjectType, subjectId])
  @@index([guildId, subjectType, allow, command])
}

model Warning {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([guildId, userId, createdAt])
  @@index([guildId, createdAt])
}

model TimedAction {
  id         String           @id @default(cuid())
  guildId    String
  userId     String
  actionType TimedActionType
  expiresAt  DateTime
  status     TimedActionStatus
  createdAt  DateTime         @default(now())
  guild      Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([guildId, status, expiresAt])
  @@index([guildId, actionType, status])
}

model RolePersistenceSnapshot {
  guildId   String
  userId    String
  roleIds   String[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
  @@index([guildId, userId])
}

model ReactionRoleMessage {
  id        String                @id
  guildId   String
  channelId String
  groupId   String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  guild     Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  mappings  ReactionRoleMapping[]

  @@index([guildId])
  @@index([guildId, groupId])
  @@index([guildId, channelId])
}

model ReactionRoleMapping {
  messageId String
  emoji     String
  roleId    String
  createdAt DateTime            @default(now())
  message   ReactionRoleMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, emoji])
  @@index([messageId, roleId])
}
