generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubjectType {
  USER
  ROLE
}

model HealthProbe {
  id        String   @id @default(cuid())
  message   String   @default("ok")
  createdAt DateTime @default(now())

  @@map("health_probes")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Guild {
  id                  String               @id
  name                String
  ownerId             String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  allowlistedGuild    AllowlistedGuild?
  permissionOverrides PermissionOverride[]
}

model AllowlistedGuild {
  guildId   String   @id
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model PermissionOverride {
  guildId     String
  subjectId   String
  subjectType SubjectType
  command     String
  allow       Boolean
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  guild       Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([guildId, subjectId, subjectType, command])
  @@index([guildId, command])
  @@index([guildId, subjectType, subjectId])
  @@index([guildId, subjectType, allow, command])
}
